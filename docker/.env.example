# Render / Docker environment — set these in the host's env (NOT in git).

# Port: Render injects PORT automatically; the server reads API_PORT || PORT.
# You can leave API_PORT unset on Render, or set API_PORT=10000.
API_PORT=10000
API_HOST=0.0.0.0

PUBLIC_BASE_URL=https://<your-render-subdomain>.onrender.com

# MongoDB Atlas. Render's egress IP is dynamic, so the Atlas network allowlist
# must include 0.0.0.0/0. For production data:
#   MONGODB_DB=pictureAir_inventory
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/
MONGODB_DB=pictureAir_inventory

# Shared secret for the externally-triggered daily stock check:
#   POST /api/cron/daily-check   header  X-Cron-Secret: <this value>
CRON_SECRET=<random_long_string>

# Email (optional). Configure SMTP in the app's Email Alerts settings, or set
# SMTP env here if you wire it that way.
